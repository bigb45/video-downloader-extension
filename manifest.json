{
  "manifest_version": 3,
  "name": "PL Video Downloader",
  "version": "1.0.0",
  "description": "Detects and downloads HLS/DASH chunked video streams with audio from any website",
  "permissions": [
    "webRequest",
    "storage",
    "downloads",
    "tabs",
    "scripting",
    "offscreen"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PL Video Downloader",
    "default_icon": {
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["offscreen.html", "lib/ffmpeg/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
